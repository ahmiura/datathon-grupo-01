{
  "title": "Datathon - API & LLM Observability",
  "tags": ["mlops", "fastapi"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 36,
  "panels": [
    {
      "type": "stat",
      "title": "Requisições em Andamento (Em Tempo Real)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "value" },
          "mappings": [
            { "options": { "match": "null" }, "type": "special", "value": { "color": "green", "text": "0" } }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Total de Requisições Processadas",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Taxa de Sucesso vs Erro (Status HTTP)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (http_requests_total{handler=~\"/predict|/chat\"})",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Taxa de Requisições por Endpoint (RPS)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total{handler=~\"/predict|/chat\"}[1m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latência Média (Segundos)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_request_duration_seconds_sum{handler=~\"/predict|/chat\"}[1m])) / sum by (handler) (rate(http_request_duration_seconds_count{handler=~\"/predict|/chat\"}[1m]))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2 }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latência - Percentis p80, p90 e p95 (Segundos)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.80, sum by (le, handler) (rate(http_request_duration_seconds_bucket{handler=~\"/predict|/chat\"}[1m])))",
          "legendFormat": "p80 - {{handler}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le, handler) (rate(http_request_duration_seconds_bucket{handler=~\"/predict|/chat\"}[1m])))",
          "legendFormat": "p90 - {{handler}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket{handler=~\"/predict|/chat\"}[1m])))",
          "legendFormat": "p95 - {{handler}}",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2 }
        }
      }
    }
  ]
}